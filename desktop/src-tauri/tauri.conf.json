{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mnemos",
  "version": "0.8.0",
  "identifier": "dev.mnemos.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "rm -rf dist && bash src-tauri/build-sidecars.sh && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Mnemos",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 Mnemos contributors",
    "shortDescription": "Local-first AI memory provider",
    "longDescription": "Mnemos is a local-first AI memory provider for Claude Code and other AI tools. It stores memories as markdown files in your vault and indexes them with hybrid BM25 + dense + graph PPR search.",
    "homepage": "https://github.com/UnpaidAttention/mnemos",
    "externalBin": ["binaries/mnemos-daemon", "binaries/mnemos"],
    "resources": [
      "../../assets/llama-server-linux-x86_64",
      "../../assets/all-MiniLM-L6-v2.Q8_0.gguf",
      "../../assets/Qwen3-0.6B-Q4_K_M.gguf",
      "../../assets/libllama-server-impl.so",
      "../../assets/libllama.so",
      "../../assets/libllama.so.0",
      "../../assets/libllama.so.0.0.9400",
      "../../assets/libllama-common.so",
      "../../assets/libllama-common.so.0",
      "../../assets/libllama-common.so.0.0.9400",
      "../../assets/libmtmd.so",
      "../../assets/libmtmd.so.0",
      "../../assets/libmtmd.so.0.0.9400",
      "../../assets/libggml.so",
      "../../assets/libggml.so.0",
      "../../assets/libggml.so.0.13.0",
      "../../assets/libggml-base.so",
      "../../assets/libggml-base.so.0",
      "../../assets/libggml-base.so.0.13.0",
      "../../assets/libggml-rpc.so",
      "../../assets/libggml-cpu-alderlake.so",
      "../../assets/libggml-cpu-cannonlake.so",
      "../../assets/libggml-cpu-cascadelake.so",
      "../../assets/libggml-cpu-cooperlake.so",
      "../../assets/libggml-cpu-haswell.so",
      "../../assets/libggml-cpu-icelake.so",
      "../../assets/libggml-cpu-ivybridge.so",
      "../../assets/libggml-cpu-piledriver.so",
      "../../assets/libggml-cpu-sandybridge.so",
      "../../assets/libggml-cpu-sapphirerapids.so",
      "../../assets/libggml-cpu-skylakex.so",
      "../../assets/libggml-cpu-sse42.so",
      "../../assets/libggml-cpu-x64.so",
      "../../assets/libggml-cpu-zen4.so"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"],
        "epoch": 0,
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US",
        "template": null
      },
      "nsis": null
    }
  },
  "plugins": {}
}
